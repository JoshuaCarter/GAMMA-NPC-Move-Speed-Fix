; Dorn's NPC Move Speed Fix
; Tweaks stalker NPC movement speeds for more believable combat pacing.

![stalker_movement_speeds]
	; danger
	;; crouch
	;;; walk
	danger_crouch_walk_forward 	= 1.5 ; 1.9
	danger_crouch_walk_backward	= 1.0 ; 1.5
	danger_crouch_walk_left		= 1.2 ; 1.9
	danger_crouch_walk_right 	= 1.2 ; 1.9
	;;; run
	danger_crouch_run_forward   = 3.0 ; 3.8
	danger_crouch_run_backward	= 2.0 ; 2.5
	danger_crouch_run_left		= 2.2 ; 3.0
	danger_crouch_run_right		= 2.2 ; 3.0
	;; stand
	;;; walk
	danger_stand_walk_forward	= 3.0 ; 3.8
	danger_stand_walk_backward	= 2.0 ; 2.5
	danger_stand_walk_left		= 2.2 ; 3.0
	danger_stand_walk_right		= 2.2 ; 3.0
	;;; run
	danger_stand_run_forward	= 4.5 ; 5.2
	danger_stand_run_backward	= 2.2 ; 2.5
	danger_stand_run_left		= 2.6 ; 3.5
	danger_stand_run_right		= 2.6 ; 3.5
	; free
	;; stand
	;;; forward
	free_stand_walk_forward		= 1.1 ; 1.1
	free_stand_run_forward		= 3.0 ; 3.0
	; panic
	;; stand
	;;; run
	;;;; forward
	panic_stand_run_forward		= 6.0 ; 6.0

